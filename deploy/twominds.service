[Unit]
Description=TwoMinds FastAPI application
After=network.target

[Service]
Type=simple
User=twominds
Group=twominds
WorkingDirectory=/opt/twominds
EnvironmentFile=/opt/twominds/.env
ExecStart=/opt/twominds/venv/bin/uvicorn main:app --host 127.0.0.1 --port 3000 --workers 1
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
